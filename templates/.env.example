# Variáveis públicas de exemplo para execução local.
# Nunca versionar valores reais neste arquivo; use apenas placeholders.

PROJECT_NAME=omie_xml_intake
PROJECT_ENV=local
LOG_LEVEL=INFO

# Caminhos e volumes
XML_SOURCE_PATH=/data/xml/inbox
XML_PROCESSED_PATH=/data/xml/processed
XML_REJECTED_PATH=/data/xml/rejected

# Parâmetros operacionais Omie
OMIE_TARGET_ACCOUNT_RECEIVABLE=CONTA_CORRENTE_EXEMPLO
OMIE_TARGET_ACCOUNT_RECEIVABLE_CATEGORY=CATEGORIA_EXEMPLO
OMIE_APP_KEY=preencher_localmente
OMIE_APP_SECRET=preencher_localmente

# Banco de dados de apoio
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=orbe_omie
POSTGRES_USER=orbe_user
POSTGRES_PASSWORD=preencher_localmente

# Airflow
AIRFLOW_UID=50000
AIRFLOW_FERNET_KEY=preencher_localmente
AIRFLOW_ADMIN_USERNAME=airflow
AIRFLOW_ADMIN_PASSWORD=preencher_localmente
AIRFLOW_ADMIN_EMAIL=admin@example.com

# Superset
SUPERSET_SECRET_KEY=preencher_localmente
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=preencher_localmente
SUPERSET_ADMIN_EMAIL=admin@example.com
SUPERSET_LOAD_EXAMPLES=no

# Webhooks futuros
OMIE_WEBHOOK_ENABLED=false
OMIE_WEBHOOK_BASE_URL=https://example.invalid
OMIE_WEBHOOK_SHARED_SECRET=preencher_localmente
